    "TIMED_WALK_TEST_EXPLAINER_6_MIN_WALK" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This test measures your exercise capacity by tracking how far you walk in 6 minutes on a flat surface. (For reference ranges see [here](https://mhc-6mwts.streamlit.app).)\n\n**How to:** Find a flat, obstacle-free path. Wear comfortable shoes. Tap \"Start\" and walk at a steady, comfortably challenging pace to cover maximum distance. Keep your phone in your hand until it vibrates."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This test measures your exercise capacity by tracking how far you walk in 6 minutes on a flat surface. (For reference ranges see [here](https://mhc-6mwts.streamlit.app).)\n\n**How to:** Find a flat, obstacle-free path. Wear comfortable shoes. Tap \"Start\" and walk at a steady, comfortably challenging pace to cover maximum distance. Keep your phone in your hand until it vibrates."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta prueba mide su capacidad funcional de ejercicio al registrar la distancia que recorre caminando en 6 minutos sobre una superficie plana. (Para conocer los rangos de referencia, consulte [aquí](https://mhc-6mwts.streamlit.app).)\n\n**Cómo hacerlo:** Busque un trayecto plano y libre de obstáculos. Use calzado cómodo. Toque \"Iniciar\" y camine a un ritmo constante que le resulte exigente pero cómodo para cubrir la mayor distancia posible. Mantenga su teléfono en la mano hasta que vibre."
          }
        }
      }
    },
    "TIMED_WALK_TEST_EXPLAINER_12_MIN_RUN" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This test estimates your aerobic fitness (VO2 max) by tracking how far you run in 12 minutes on a flat surface. (For reference ranges see [here](https://www.ptdirect.com/training-delivery/client-assessment/cooper-12-minute-run-a-predictive-test-of-vo2max).)\n\n**Warm-up:** Before beginning the test, perform about 10 minutes of light jogging to loosen your muscles and avoid injury. Catch your breath before proceeding.\n\n**How to:** Find a flat, obstacle-free path or running track. Wear comfortable running shoes. When you are ready, tap \"Start\" and run as fast as you possibly can to cover maximum distance until your phone vibrates. Keep your phone in your hand until it vibrates."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This test estimates your aerobic fitness (VO2 max) by tracking how far you run in 12 minutes on a flat surface. (For reference ranges see [here](https://www.ptdirect.com/training-delivery/client-assessment/cooper-12-minute-run-a-predictive-test-of-vo2max).)\n\n**Warm-up:** Before beginning the test, perform about 10 minutes of light jogging to loosen your muscles and avoid injury. Catch your breath before proceeding.\n\n**How to:** Find a flat, obstacle-free path or running track. Wear comfortable running shoes. When you are ready, tap \"Start\" and run as fast as you possibly can to cover maximum distance until your phone vibrates. Keep your phone in your hand until it vibrates."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esté listo, toque «Iniciar» y corra lo más rápido que pueda"
          }
        }
      }
    },
    "TIMED_WALK_TEST_EXPLAINER_FOOTER" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Warning:** Stop immediately if you experience chest pain, severe shortness of breath, dizziness, or unusual fatigue."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Warning:** Stop immediately if you experience chest pain, severe shortness of breath, dizziness, or unusual fatigue."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Advertencia:** Deténgase de inmediato si presenta dolor en el pecho, falta de aire intensa, mareo o fatiga inusual."
          }
        }
      }
    },
