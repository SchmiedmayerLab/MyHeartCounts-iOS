    "WELCOME_AREA1_DESCRIPTION" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your involvement helps Stanford researchers understand how personalized digital coaching can improve physical activity and your overall health today and in the future."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your involvement helps Stanford researchers understand how personalised digital coaching can improve physical activity and your overall health today and in the future."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu participación ayuda a los investigadores de Stanford a comprender cómo el entrenamiento digital personalizado puede mejorar la actividad física y tu salud general hoy y en el futuro."
          }
        }
      }
    },
    "WELCOME_AREA2_DESCRIPTION" : {
      "localizations" : {
        "en" : {
