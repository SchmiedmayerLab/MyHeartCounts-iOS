    },
    "WELCOME_AREA3_DESCRIPTION" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Participate entirely online, securely sharing your activity data directly from your iPhone and Apple Watch."
